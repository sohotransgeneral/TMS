{
  "framework": "nextjs",
  "buildCommand": "npx prisma generate && npx next build",
  "installCommand": "npm install --legacy-peer-deps",
  "outputDirectory": ".next",
  "functions": {
    "app/api/upload/route.ts": { "maxDuration": 60 },
    "app/api/upload-proof/route.ts": { "maxDuration": 30 }
  },
  "crons": [
    {
      "path": "/api/cron/purge-notifications",
      "schedule": "0 3 * * *"
    }
  ]
}
